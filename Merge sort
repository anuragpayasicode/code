***Merge sort*** 

#include <iostream>
using namespace std;

void merge(int arr[], int start, int mid, int end)
{
    int temp[100];
    int i = start, j = mid + 1, k = start;
    while (i <= mid && j <= end)
    {
        if (arr[i] < arr[j])
        {
            temp[k++] = arr[i++];
        }
        else
        {
            temp[k++] = arr[j++];
        }
    }
    while (i <= mid)
    {
        temp[k++] = arr[i++];
    }
    while (j <= end)
    {
        temp[k++] = arr[j++];
    }

    for (int x = start; x <= end; x++)
    {
        arr[x] = temp[x];
    }
}

void mergeSort(int arr[], int start, int end)
{
    if (start >= end)
         return ;

         
        int mid = start + (end - start) / 2;
        mergeSort(arr, start, mid);
        mergeSort(arr, mid + 1, end);
        merge(arr, start, mid, end);

}

int main()
{
    int arr[] = {5, 2, 8, 1, 3};
    int n = 5;
    mergeSort(arr, 0, n - 1);

    for(int val = 0 ; val < n; val++){
        cout<<arr[val]<<" ";
    }
    return 0;
}
